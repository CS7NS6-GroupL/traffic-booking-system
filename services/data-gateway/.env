SERVICE_NAME=data-gateway
REGION=laos

# Regional data-service URLs
LAOS_DATA_URL=http://data-service-laos:8009
CAMBODIA_DATA_URL=http://data-service-cambodia:8009
ANDORRA_DATA_URL=http://data-service-andorra:8009

# MongoDB Atlas connection string for read fallback when a regional
# data-service is unreachable. Leave blank to disable Atlas fallback.
# Example: mongodb+srv://user:pass@cluster.mongodb.net/traffic?retryWrites=true
MONGO_ATLAS_URI=

JWT_SECRET=changeme-use-a-real-secret-in-production
JWT_ALGORITHM=HS256
