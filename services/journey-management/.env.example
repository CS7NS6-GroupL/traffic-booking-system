SOUTH_ASIA_ROUTE_URL=http://route-service:8000
NORTH_AMERICA_ROUTE_URL=http://route-service:8000

# OSM node IDs at physical land border crossings between regions.
# Find these after OSM data import — see journey-management README for queries.
GATEWAY_EU_ME=
GATEWAY_ME_SA=
