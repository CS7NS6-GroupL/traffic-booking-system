SERVICE_NAME=journey-management
REGION=local
MONGO_URI=mongodb://mongo:27017
REDIS_URL=redis://redis:6379
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
JWT_SECRET=changeme-use-a-real-secret-in-production
JWT_ALGORITHM=HS256

# Regional route-service URLs (in production each points to a separate cluster)
EUROPE_ROUTE_URL=http://route-service:8000
MIDDLE_EAST_ROUTE_URL=http://route-service:8000
SOUTH_ASIA_ROUTE_URL=http://route-service:8000
NORTH_AMERICA_ROUTE_URL=http://route-service:8000

# OSM node IDs at the Bulgaria/Turkey border crossing (Kapitan Andreevo).
# These differ because Bulgaria and Turkey OSM extracts use separate node IDs.
# Find them after OSM data import — see journey-management README for queries.
GATEWAY_EU_EXIT=    # Bulgaria side (europe region graph)
GATEWAY_ME_ENTRY=   # Turkey side (middle-east region graph)
