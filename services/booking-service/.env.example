# ── Required ───────────────────────────────────────────────────────────────────
# Change this before deploying — any long random string works
JWT_SECRET=changeme-use-a-real-secret-in-production

# ── Service identity ───────────────────────────────────────────────────────────
SERVICE_NAME=booking-service
REGION=local                         # eu | us | asia | local

# ── Upstream dependencies ──────────────────────────────────────────────────────
# In Docker Compose these resolve via container names.
# For standalone deployment, point to the live hosted URLs.
JOURNEY_MANAGEMENT_URL=http://journey-management:8000
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
MONGO_URI=mongodb://mongo:27017
